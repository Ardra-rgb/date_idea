<div class="container">

    <h1>💖 Pick Our Date 💖</h1>

    <div class="date-layout">

        <!-- Left Side -->
        <div class="calendar-section">

            <h2 class="section-title">
                📅 Choose a Date
            </h2>

            <input
                id="calendar"
                type="text">

        </div>

        <!-- Right Side -->
        <div class="time-section">

            <h2 class="time-title">
                What time works best?
            </h2>

            <div class="time-options">

                <div class="time-card">
                    <div class="time-emoji">☀️</div>
                    <p>Morning</p>
                </div>

                <div class="time-card">
                    <div class="time-emoji">🌤</div>
                    <p>Afternoon</p>
                </div>

                <div class="time-card">
                    <div class="time-emoji">🌇</div>
                    <p>Evening</p>
                </div>

                <div class="time-card">
                    <div class="time-emoji">🌙</div>
                    <p>Night</p>
                </div>

            </div>

            <button
                class="continue-btn"
                onclick="window.location='/perfect_date/index'">
                Continue ❤️
            </button>

        </div>

    </div>

</div>